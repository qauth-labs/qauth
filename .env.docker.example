# QAuth Docker Environment Variables
# Copy this file to .env and fill in the required values

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection is automatically configured by docker-compose
# DATABASE_URL is set automatically based on DB_PASSWORD below
DB_PASSWORD=qauth_dev_password

# Database Pool Configuration (optional)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# =============================================================================
# Redis Configuration
# =============================================================================
# Redis connection is automatically configured by docker-compose
# REDIS_URL is set automatically
# Optional: Set a password for Redis (leave empty for no password)
REDIS_PASSWORD=

# Redis database number (0-15)
REDIS_DB=0

# Redis Connection Pool Configuration (optional)
REDIS_MAX_RETRIES=3
REDIS_CONNECTION_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000

# =============================================================================
# JWT Configuration (REQUIRED)
# =============================================================================
# Generate EdDSA key pair for JWT signing:
#
#   openssl genpkey -algorithm Ed25519 -out private.pem
#   openssl pkey -in private.pem -pubout -out public.pem
#
# Then set the keys below. You can either:
# 1. Use environment variables (paste the full key including BEGIN/END lines)
# 2. Use file paths (set JWT_PRIVATE_KEY_PATH and JWT_PUBLIC_KEY_PATH)

# Option 1: Environment Variables (paste full key including BEGIN/END lines)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VwBCIEI...
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MCowBQYDK2VwAyEA...
-----END PUBLIC KEY-----"

# Option 2: File Paths (alternative to environment variables)
# JWT_PRIVATE_KEY_PATH=/path/to/private.pem
# JWT_PUBLIC_KEY_PATH=/path/to/public.pem

# JWT issuer URL (required)
JWT_ISSUER=http://localhost:3000

# Token expiration (optional, defaults shown)
ACCESS_TOKEN_LIFESPAN=900
REFRESH_TOKEN_LIFESPAN=604800

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# Authentication Configuration
# =============================================================================
DEFAULT_REALM_NAME=master
SYSTEM_CLIENT_ID=system

# Rate Limiting
REGISTRATION_RATE_LIMIT=3
REGISTRATION_RATE_WINDOW=3600
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=900

# =============================================================================
# Password Configuration
# =============================================================================
# Argon2id password hashing configuration
PASSWORD_MEMORY_COST=65536
PASSWORD_TIME_COST=3
PASSWORD_PARALLELISM=4
PASSWORD_MIN_SCORE=2

# =============================================================================
# Email Configuration
# =============================================================================
# Email provider: 'mock', 'resend', or 'smtp'
# 'mock' logs emails to console (good for local development)
EMAIL_PROVIDER=mock

# Default sender information
EMAIL_FROM_ADDRESS=noreply@qauth.dev
EMAIL_FROM_NAME=QAuth

# Base URL for email links (e.g., verification links)
EMAIL_BASE_URL=http://localhost:3000

# Email verification token expiry in seconds (default: 86400 = 24 hours)
EMAIL_VERIFICATION_TOKEN_EXPIRY=86400

# Whether to invalidate existing tokens when resending verification email
EMAIL_VERIFICATION_INVALIDATE_EXISTING_ON_RESEND=true

# Resend Provider Configuration (required if EMAIL_PROVIDER=resend)
# Get your API key from https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# SMTP Provider Configuration (required if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your_smtp_password

# =============================================================================
# CORS Configuration
# =============================================================================
# CORS allowed origin (use * for all origins, or specify a domain)
CORS_ORIGIN=*

# =============================================================================
# Rate Limiting (Global)
# =============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=3600

# Email verification endpoint rate limits
VERIFICATION_RATE_LIMIT=10
VERIFICATION_RATE_WINDOW=900

# Resend verification endpoint rate limits
RESEND_VERIFICATION_RATE_LIMIT=100
RESEND_VERIFICATION_RATE_WINDOW=60
RESEND_VERIFICATION_EMAIL_LIMIT=3
RESEND_VERIFICATION_EMAIL_WINDOW=3600
RESEND_VERIFICATION_MIN_INTERVAL=60
