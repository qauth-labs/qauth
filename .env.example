# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://qauth:password@localhost:5432/qauth_dev
DATABASE_URL=postgresql://qauth:password@localhost:5432/qauth_dev

# Database Pool Configuration (optional)
# Maximum number of clients in the pool
DB_POOL_MAX=20

# Minimum number of clients in the pool
DB_POOL_MIN=2

# Number of milliseconds a client is allowed to remain idle before being closed
DB_POOL_IDLE_TIMEOUT=10000

# Number of milliseconds to wait before timing out when connecting a new client
DB_POOL_CONNECTION_TIMEOUT=2000

# Redis Configuration
# Redis connection URL (primary method)
# Format: redis://username:password@host:port/database
# Example: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Alternative Redis configuration (if REDIS_URL is not provided)
# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (optional)
# REDIS_PASSWORD=your_redis_password

# Redis database number (0-15)
REDIS_DB=0

# Redis Connection Pool Configuration
# Maximum number of connections in the pool
REDIS_MAX_CONNECTIONS=10

# Minimum number of connections in the pool
REDIS_MIN_CONNECTIONS=2

# Connection timeout in milliseconds
REDIS_CONNECTION_TIMEOUT=10000

# Command timeout in milliseconds
REDIS_COMMAND_TIMEOUT=5000

# Retry configuration
# Maximum number of retry attempts
REDIS_MAX_RETRIES=3

# Server Configuration
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:3000

# Rate Limiting Configuration
# Global rate limit - maximum number of requests per time window
RATE_LIMIT_MAX=100

# Global rate limit - time window in seconds
RATE_LIMIT_WINDOW=3600

# Registration endpoint rate limit - maximum number of requests per time window
REGISTRATION_RATE_LIMIT=3

# Registration endpoint rate limit - time window in seconds
REGISTRATION_RATE_WINDOW=3600

# Authentication Configuration
# Default realm name for new user registrations
DEFAULT_REALM_NAME=master

# Password Configuration
# Minimum password strength score (0-4, where 0=very weak, 4=strong)
# Default: 2 (Fair)
PASSWORD_MIN_SCORE=2

# Argon2id password hashing configuration
# Memory cost in KB (default: 65536 = 64MB)
PASSWORD_MEMORY_COST=65536

# Time cost / iterations (default: 3)
PASSWORD_TIME_COST=3

# Parallelism / threads (default: 4)
PASSWORD_PARALLELISM=4

# Test Configuration (optional, for test environments)
# TEST_DATABASE_URL=postgresql://qauth:password@localhost:5432/qauth_test
# TEST_REDIS_URL=redis://localhost:6379/1
