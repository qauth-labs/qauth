# Auth Server – Development Dockerfile
# Uses nx serve --watch; pair with docker-compose.dev.yml + Compose Watch (sync).

FROM node:24-alpine

WORKDIR /app

RUN corepack enable

# Workspace and config (needed before install for pnpm workspace)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY libs ./libs
COPY apps ./apps
COPY nx.json tsconfig.base.json ./
COPY vitest.config.ts ./
RUN pnpm install --frozen-lockfile

RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001 && \
    chown -R nodejs:nodejs /app

USER nodejs

EXPOSE 3000

# Nx serve --watch: build on change, restart node
CMD ["pnpm", "nx", "serve", "auth-server", "--watch"]
