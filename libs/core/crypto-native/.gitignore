# napi-rs / Rust build artifacts — the native addon is built locally and (in
# the deferred CI half of #244) by a per-platform prebuild matrix; it is never
# committed.
target/
*.node
# Checksum sidecar written next to each built addon (#277). Verified before
# dlopen; produced by the build, never committed.
*.node.sha256
# napi CLI JS/d.ts glue (regenerated on build)
index.js
index.d.ts
