{
  "name": "cache",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/data-access/cache/src",
  "projectType": "library",
  "tags": ["scope:data-access", "type:cache"],
  "// targets": "to see all targets run: nx show project cache --web",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/data-access/cache/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/data-access/cache/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "metadata": {
    "description": "Redis connection and caching utilities for QAuth",
    "version": "1.0.0",
    "author": "QAuth Team",
    "keywords": ["redis", "cache", "session", "rate-limit", "auth"],
    "dependencies": {
      "ioredis": "^5.8.2"
    }
  }
}
