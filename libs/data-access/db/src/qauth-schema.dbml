Table "roles" {
  "id" uuid [pk, default: `uuidv7()`]
  "realm_id" uuid [not null, ref: > realms.id]
  "name" varchar(255) [not null]
  "description" text
  "oauth_client_id" uuid [ref: > oauth_clients.id, note: "Client-specific roles (if set, role is scoped to that client)"]
  "enabled" boolean [not null, default: true]
  "metadata" jsonb
  "created_at" bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::bigint * 1000`]
  "updated_at" bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::bigint * 1000`]

  Indexes {
    (realm_id, name, oauth_client_id) [unique, name: "idx_roles_realm_name_unique"]
    name [name: "idx_roles_name"]
    realm_id [name: "idx_roles_realm_id"]
    oauth_client_id [name: "idx_roles_oauth_client_id"]
  }
}

Table "user_roles" {
  "user_id" uuid [not null, ref: > users.id]
  "role_id" uuid [not null, ref: > roles.id]
  "assigned_at" bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::bigint * 1000`]
  "assigned_by" uuid [ref: > users.id]

  Indexes {
    (user_id, role_id) [pk, name: "user_roles_pk"]
    user_id [name: "idx_user_roles_user_id"]
    role_id [name: "idx_user_roles_role_id"]
  }
}

// ============================================================================
// RELATIONSHIPS
// ============================================================================

// Note: Foreign key relationships are defined inline in table definitions above
// using the ref: syntax. The following are additional relationship notes:

// REALMS (Multi-tenancy):
// - Each realm is an isolated tenant
// - Realms can have multiple users, clients, roles, etc.
// - All data is scoped to a realm for isolation

// Users can have:
// - Belongs to one realm
// - Multiple email verification tokens
// - Multiple authorization codes
// - Multiple refresh tokens
// - Multiple sessions
// - Multiple audit logs
// - Multiple OAuth clients (as developer)
// - Multiple roles (via user_roles)

// OAuth clients can have:
// - Belongs to one realm
// - Multiple authorization codes (via oauth_client_id)
// - Multiple refresh tokens (via oauth_client_id)
// - Multiple sessions (via oauth_client_id)
// - Multiple roles (client-specific, via oauth_client_id)
// - Multiple audit logs (via oauth_client_id)

// Roles can have:
// - Belongs to one realm
// - Multiple users (via user_roles)
// - Optionally scoped to a specific client

