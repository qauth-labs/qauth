{
  "name": "fastify-plugin-jwt",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/fastify/plugins/jwt/src",
  "projectType": "library",
  "tags": ["scope:fastify", "type:jwt"],
  "// targets": "to see all targets run: nx show project fastify-plugin-jwt --web",
  "targets": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "options": {
        "cwd": "libs/fastify/plugins/jwt",
        "command": "tsc --build --emitDeclarationOnly"
      },
      "cache": true,
      "inputs": [
        "default",
        {
          "dependentTasksOutputFiles": "**/*.d.ts"
        }
      ],
      "outputs": [
        "{workspaceRoot}/dist/out-tsc/**/*.d.ts",
        "{workspaceRoot}/dist/out-tsc/libs/fastify/plugins/jwt/*.tsbuildinfo"
      ]
    }
  }
}
