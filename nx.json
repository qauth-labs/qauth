{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json",
          "buildDepsName": "build-deps",
          "watchDepsName": "watch-deps"
        }
      },
      "exclude": [
        "libs/infra/db/*",
        "libs/infra/cache/*",
        "libs/fastify/plugins/db/*",
        "libs/fastify/plugins/cache/*",
        "libs/fastify/plugins/password/*",
        "libs/fastify/plugins/email/*",
        "libs/fastify/plugins/jwt/*",
        "libs/shared/errors/*",
        "libs/server/config/*",
        "libs/server/email/*",
        "libs/server/password/*",
        "libs/shared/validation/*",
        "libs/shared/testing/*",
        "libs/server/jwt/*",
        "libs/server/pkce/*",
        "libs/server/federation/*",
        "libs/fastify/plugins/pkce/*",
        "libs/fastify/plugins/federation/*",
        "libs/core/crypto/*",
        "libs/core/crypto-native/*"
      ]
    },
    {
      "plugin": "@nx/js/typescript",
      "include": [
        "libs/infra/db/*",
        "libs/infra/cache/*",
        "libs/fastify/plugins/db/*",
        "libs/fastify/plugins/cache/*",
        "libs/fastify/plugins/password/*",
        "libs/fastify/plugins/email/*",
        "libs/fastify/plugins/jwt/*",
        "libs/shared/errors/*",
        "libs/server/config/*",
        "libs/server/email/*",
        "libs/server/password/*",
        "libs/shared/validation/*",
        "libs/shared/testing/*",
        "libs/server/jwt/*",
        "libs/server/pkce/*",
        "libs/server/federation/*",
        "libs/fastify/plugins/pkce/*",
        "libs/fastify/plugins/federation/*",
        "libs/core/crypto/*",
        "libs/core/crypto-native/*"
      ],
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        }
      }
    },
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "test",
        "testMode": "run"
      }
    },
    {
      "plugin": "@nx/vite/plugin",
      "options": {
        "buildTargetName": "build",
        "previewTargetName": "preview",
        "serveTargetName": "serve",
        "devTargetName": "dev",
        "serveStaticTargetName": "serve-static",
        "typecheckTargetName": "typecheck",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps"
      }
    }
  ],
  "targetDefaults": {
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"]
    }
  },
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/.github/workflows/ci.yml",
      // Every project's vitest.config.ts mergeConfig()s the root one, so a
      // change there (exclude globs, coverage thresholds) must invalidate every
      // test target. The @nx/vitest inferred targets do not list it themselves.
      "{workspaceRoot}/vitest.config.ts"
    ],
    // #285: this was `["sharedGlobals"]`, dropping Nx's built-in
    // `{projectRoot}/**/*` entry. Every `default`-hashed target (test, build)
    // therefore hashed only ci.yml and ignored the project's own sources, so a
    // cached green `test` result was replayed even after a failing spec was
    // added. Keep `{projectRoot}/**/*` first — it is what makes a source edit
    // invalidate the task.
    "default": ["{projectRoot}/**/*", "sharedGlobals"]
  },
  "sync": {
    "disabledTaskSyncGenerators": ["@nx/js:typescript-sync"]
  },
  "analytics": false
}
