{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "nxCloudId": "68ed5766d0a8584639447f54",
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json",
          "buildDepsName": "build-deps",
          "watchDepsName": "watch-deps"
        }
      },
      "exclude": [
        "libs/data-access/db/*",
        "libs/data-access/cache/*",
        "libs/fastify-plugin/db/*",
        "libs/fastify-plugin/cache/*",
        "libs/common/errors/*",
        "libs/common/validation/*",
        "libs/common/password/*"
      ]
    },
    {
      "plugin": "@nx/js/typescript",
      "include": [
        "libs/data-access/db/*",
        "libs/data-access/cache/*",
        "libs/fastify-plugin/db/*",
        "libs/fastify-plugin/cache/*",
        "libs/common/errors/*",
        "libs/common/validation/*",
        "libs/common/password/*"
      ],
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        }
      }
    }
  ],
  "targetDefaults": {
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"]
    }
  }
}
