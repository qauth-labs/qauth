{
  "name": "qauth",
  "version": "0.0.0",
  "description": "Post-quantum ready, headless-first identity platform. A developer-friendly alternative to Keycloak.",
  "license": "Apache-2.0",
  "author": "QAuth Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/qauth-labs/qauth.git"
  },
  "keywords": [
    "authentication",
    "authorization",
    "oauth2",
    "oidc",
    "sso",
    "identity",
    "security",
    "jwt",
    "keycloak-alternative"
  ],
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "nx serve",
    "build": "nx build",
    "test": "nx test",
    "lint": "nx lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "**/*.{js,jsx,json,yml,yaml,css,less,scss,ts,tsx,md,graphql}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.8.0",
    "@nx/esbuild": "^22.1.3",
    "@nx/eslint": "^22.1.3",
    "@nx/eslint-plugin": "^22.1.3",
    "@nx/js": "^22.1.3",
    "@nx/node": "^22.1.3",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.3",
    "@swc/helpers": "~0.5.11",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nx": "^22.1.3",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "@fastify/autoload": "^6.0.3",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  }
}
