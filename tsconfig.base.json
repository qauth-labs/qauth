{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@qauth/constants": ["libs/shared/constants/src/index.ts"],
      "@qauth/db": ["libs/data-access/db/src/index.ts"],
      "@qauth/redis": ["libs/data-access/redis/src/index.ts"],
      "@qauth/types": ["libs/shared/types/src/index.ts"],
      "@qauth/utils": ["libs/shared/utils/src/index.ts"]
    },
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "tmp", "dist", "out-tsc", "coverage", ".nx"]
}
