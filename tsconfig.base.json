{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "moduleResolution": "node",
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@qauth/infra-cache": ["libs/infra/cache/src/index.ts"],
      "@qauth/infra-db": ["libs/infra/db/src/index.ts"],
      "@qauth/fastify-plugin-db": ["libs/fastify/plugins/db/src/index.ts"],
      "@qauth/fastify-plugin-cache": ["libs/fastify/plugins/cache/src/index.ts"],
      "@qauth/fastify-plugin-password": ["libs/fastify/plugins/password/src/index.ts"],
      "@qauth/fastify-plugin-email": ["libs/fastify/plugins/email/src/index.ts"],
      "@qauth/shared-errors": ["libs/shared/errors/src/index.ts"],
      "@qauth/shared-validation": ["libs/shared/validation/src/index.ts"],
      "@qauth/shared-testing": ["libs/shared/testing/src/index.ts"],
      "@qauth/server-password": ["libs/server/password/src/index.ts"],
      "@qauth/server-email": ["libs/server/email/src/index.ts"],
      "@qauth/server-config": ["libs/server/config/src/index.ts"]
    },
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "tmp", "dist", "out-tsc", "coverage", ".nx"]
}
